{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "capybara",
  "version": "0.1.0",
  "identifier": "com.capybara.capybara-app",
  "build": {
    "beforeDevCommand": "bun run setup:bun && bun run build:agent && bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run setup:bun && bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "capybara",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/bun"
    ],
    "resources": [
      "vendor/lima/bin/**/*",
      "vendor/lima/share/lima/**/*",
      "vendor/lima/libexec/lima/**/*",
      "resources/capybara-agent/index.js",
      "resources/supervisor/capybara_supervisor.py"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
