{
  "name": "capybara",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "agent"
  ],
  "scripts": {
    "setup:bun": "bash ./src-tauri/scripts/fetch-bun-sidecar.sh",
    "build:agent": "bun run --cwd agent build",
    "check:agent": "bun run --cwd agent check",
    "dev": "vite",
    "build": "bun run check:agent && bun run build:agent && tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "setup": "bash ./src-tauri/scripts/fetch-lima.sh && bun run setup:bun",
    "test:supervisor:image": "docker build -f src-tauri/resources/supervisor/Dockerfile.test -t capybara-supervisor-test src-tauri/resources/supervisor",
    "test:supervisor": "docker run --rm --privileged -v \"$PWD/src-tauri/resources/supervisor:/app:ro\" -w /app capybara-supervisor-test sh -lc 'CAPYBARA_SUPERVISOR_INTEGRATION=1 pytest -q -p no:cacheprovider'"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "@tauri-apps/cli": "^2.11.0"
  }
}
